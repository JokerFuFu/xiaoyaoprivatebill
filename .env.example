# 小遥账单助手 - 环境变量模板
# 用法：复制本文件为 .env（与 docker-compose.yml 同目录），按需修改后 `docker-compose up -d`。
# 不设也能跑：所有项都有默认值；.env 已被 .gitignore 忽略，不会进版本库。

# ============ 管理员账号（仅首次启动创建一次，之后改这里无效，请在「设置 → 账号」里改密码）============
# 默认账号 admin / admin12345（登录页会自动带入，方便首次进入）。
# 一旦在下面设置了 ADMIN_PASSWORD，登录页就不再展示默认密码——请记好你设置的值。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_DISPLAY=管理员

# 登录会话密钥：留空则自动生成并持久化到 data/.flask_secret（重启不掉登录）。
# 多实例部署可固定一个长随机串保证会话一致。
FLASK_SECRET_KEY=

# ============ AI 助手（完全可选）============
# 不填 ANTHROPIC_API_KEY 也能用全部账单分析功能，只是首页/智能分析的「AI 对话」不可用。
# 兼容任意 Anthropic 格式端点（默认 Kimi）。Key 也可登录后在「设置 → AI 与模型」里填，二选一即可。
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
ANTHROPIC_API_KEY=
AI_MODEL=kimi-k2-0905-preview
